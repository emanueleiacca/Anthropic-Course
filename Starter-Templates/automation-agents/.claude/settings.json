{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "claude-opus-4-7",
  "effortLevel": "high",
  "defaultMode": "default",
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PLAYWRIGHT_BROWSERS_PATH": "0",
    "TZ": "UTC"
  },
  "permissions": {
    "allow": [
      "Read", "Glob", "Grep", "Edit", "Write",
      "Bash(uv sync)",
      "Bash(uv add:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run mypy:*)",
      "Bash(uv run python -m *)",
      "Bash(uv run playwright install:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh pr *)"
    ],
    "ask": [
      "Bash(uv run pytest -m e2e*)",
      "Bash(uv run python -m * run-prod*)",
      "Bash(docker compose down*)",
      "Bash(git push:*)",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(* DROP TABLE *)",
      "Bash(docker system prune*)",
      "Read(./.env*)",
      "Read(**/credentials*)",
      "Read(**/*.pem)"
    ]
  },
  "enabledMcpjsonServers": ["github", "filesystem", "playwright", "memory"]
}
